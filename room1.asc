// room script file

function ExitBedroom_WalkOn(Hotspot *theHotspot)
{
  player.ChangeRoom(2, 570,  190);
}

function closedCabinet_Interact(Object *theObject, CursorMode mode)
{
  player.Say("It's locked. I should use my key in my pocket.");
}

function closedCabinet_Look(Object *theObject, CursorMode mode)
{
  player.Say("It's my cabinet. I should get changed.");
}

function closedCabinet_UseInv(Object *theObject, CursorMode mode)
{
  if (player.ActiveInventory == iKey) {
    player.Walk(82, 162, eBlock);
    player.Say("It's Open.");
    Display("You open the cabinet with your key. You change into your clothes.");
    theObject.Visible = false;
    openCabinet.Visible = true;
  }
}

function oObject0_Interact(Object *theObject, CursorMode mode)
{

}
