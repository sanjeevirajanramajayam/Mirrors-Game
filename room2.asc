// room script file

function EnterBedroom_WalkOn(Hotspot *theHotspot)
{
  player.ChangeRoom(1,  140,  160);
}

function EnterBathroom_WalkOn(Hotspot *theHotspot)
{
  player.ChangeRoom(4, 68, 162);
}

function EnterCellar_WalkOn(Hotspot *theHotspot)
{
  player.ChangeRoom(5, 81, 159);
}

function EnterOffice_WalkOn(Hotspot *theHotspot)
{
  player.ChangeRoom(3, 117, 161);
}
